# EditorConfig - https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# PHP: Tabs per WordPress Coding Standards.
[*.php]
indent_style = tab
indent_size = 4

# JavaScript, CSS, JSON, YAML: Tabs per WordPress JS Coding Standards.
[*.{js,jsx,css,json,yml,yaml}]
indent_style = tab
indent_size = 4

# Markdown: allow trailing whitespace for line breaks.
[*.md]
trim_trailing_whitespace = false
