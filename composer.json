{
	"name": "starter-plugin/starter-plugin",
	"description": "A starter WordPress plugin scaffolded by WP Crucible.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "Your Name",
			"homepage": "https://example.com"
		}
	],
	"autoload": {
		"psr-4": {
			"StarterPlugin\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"StarterPlugin\\Tests\\": "tests/"
		}
	},
	"require": {
		"php": ">=8.1"
	},
	"require-dev": {
		"brain/monkey": "2.7.0",
		"dealerdirect/phpcodesniffer-composer-installer": "1.2.1",
		"php-stubs/wordpress-stubs": "6.9.1",
		"phpcompatibility/phpcompatibility-wp": "2.1.8",
		"phpstan/extension-installer": "1.4.3",
		"phpstan/phpstan": "2.1.55",
		"phpunit/phpunit": "10.5.62",
		"squizlabs/php_codesniffer": "3.13.5",
		"szepeviktor/phpstan-wordpress": "2.0.3",
		"wp-coding-standards/wpcs": "3.3.0",
		"yoast/phpunit-polyfills": "2.0.5"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true,
			"phpstan/extension-installer": true
		},
		"platform": {
			"php": "8.1.0"
		},
		"sort-packages": true
	},
	"scripts": {
		"lint": "phpcs",
		"lint:fix": "phpcbf",
		"analyze": "phpstan analyze --memory-limit=512M",
		"test": "phpunit --testsuite Unit",
		"check": [
			"@lint",
			"@analyze",
			"@test"
		]
	}
}
